#!/bin/bash

#
# Input configuration
#
riverctl keyboard-layout          hu
riverctl focus-follows-cursor     always
riverctl set-repeat               45 300
riverctl hide-cursor when-typing  enabled
#riverctl input pointer-2-14-ETPS/2_Elantech_Touchpad events disabled
riverctl input pointer-2-14-ETPS/2_Elantech_Touchpad click-pointer-2-14-ETPS/2_Elantech_Touchpadmethod clickfinger
riverctl input pointer-2-14-ETPS/2_Elantech_Touchpad tap enabled
riverctl input pointer-2-14-ETPS/2_Elantech_Touchpad drag enabled
riverctl input pointer-2-14-ETPS/2_Elantech_Touchpad drag-lock enabled
riverctl input pointer-2-14-ETPS/2_Elantech_Touchpad disable-while-typing enabled
riverctl input pointer-2-14-ETPS/2_Elantech_TrackPoint accel-profile none
riverctl input pointer-2-14-ETPS/2_Elantech_TrackPoint pointer-accel -0.2

#
# Key bindings
#
# Spawn things
riverctl map normal Alt         P                       spawn 'rofi -show run' # App launcher
riverctl map normal Alt+Shift   B                       spawn 'rofi-bluetooth' # Bluetooth manager
riverctl map normal Alt         I                       spawn 'rofi-pass' # Password manager
riverctl map normal Alt+Shift   N                       spawn 'rofi -show "WIFI" -modi "WIFI:iwdrofimenu"' # Network manager
riverctl map normal Alt+Shift   Return                  spawn 'foot' # Terminal
riverctl map normal Alt+Shift   F                       spawn 'foot -e yazi' # File manager
riverctl map normal Alt+Shift   S                       spawn 'foot -e pulsemixer' # Audio mixer
riverctl map normal Alt+Shift   W                       spawn 'chromium' # Web browser
riverctl map normal Super       L                       spawn 'swaylock -p -C ~/.config/swaylock/chclr.conf --font "MonaspiceRn NF" --font-size 13' # Lock screen
riverctl map normal Super       G                       spawn 'grep performance /sys/devices/system/cpu/cpu0/cpufreq/scaling_governor > /dev/null && sudo tlp bat || sudo tlp ac' # Power profile toggle
riverctl map normal Super       P                       spawn 'way-displays -d DISABLED "eDP-1" | grep -o "No config changes" && way-displays -s DISABLED "eDP-1"' # Disable/enable laptop screen
riverctl map normal Alt+Shift   M                       spawn 'wl-mirror eDP-1' # Mirror laptop screen
riverctl map normal None        Print                   spawn 'grim -g "$(slurp)" - | tee "$HOME/Pictures/$(date +%Y-%m-%d_%H-%m-%S).png" | wl-copy -t image/png' # Screenshot
riverctl map normal Super       Minus                   spawn 'dunstify "River keybindings" "$(grep "map normal" .config/river/init | grep "#" | grep -v "init" | awk '"'"'{match($0, /#\s*(.*)/, arr); print $4 "+" $5, "=>", arr[1]}'"'"' | sort)"'
###### Laptop specific keys ######
riverctl map normal None        XF86AudioMute           spawn 'wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle'
riverctl map normal None        XF86AudioLowerVolume    spawn 'wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%- -l 1.2'
riverctl map normal None        XF86AudioRaiseVolume    spawn 'wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%+ -l 1.2'
riverctl map normal None        XF86AudioMicMute        spawn 'pactl set-source-mute @DEFAULT_SOURCE@ toggle'
riverctl map normal None        XF86MonBrightnessDown   spawn 'brightnessctl set 5%-'
riverctl map normal None        XF86MonBrightnessUp     spawn 'brightnessctl set 5%+'

# Layout stuff
riverctl map normal Alt+Shift   C         close
riverctl map normal Alt+Shift   Q         exit
riverctl map normal Alt         Return    zoom
riverctl map normal Alt         J         focus-view next
riverctl map normal Alt         K         focus-view previous
riverctl map normal Alt         Period    focus-output next
riverctl map normal Alt         Comma     focus-output previous
riverctl map normal Alt+Shift   Period    send-to-output next
riverctl map normal Alt+Shift   Comma     send-to-output previous
riverctl map normal Alt         G         toggle-fullscreen
riverctl map normal Alt         F         toggle-float
riverctl map normal Alt         E         send-layout-cmd rivercarro "main-count +1"
riverctl map normal Alt         Q         send-layout-cmd rivercarro "main-count -1"
riverctl map normal Alt         H         send-layout-cmd rivercarro "main-ratio -0.05"
riverctl map normal Alt         L         send-layout-cmd rivercarro "main-ratio +0.05"
riverctl map normal Alt         W         send-layout-cmd rivercarro "main-location top"
riverctl map normal Alt         S         send-layout-cmd rivercarro "main-location bottom"
riverctl map normal Alt         A         send-layout-cmd rivercarro "main-location left"
riverctl map normal Alt         D         send-layout-cmd rivercarro "main-location right"
riverctl map normal Alt         M         send-layout-cmd rivercarro "main-location monocle"
riverctl map normal None        Caps_Lock None
for i in $(seq 1 6)
do
    tags=$((1 << ($i - 1)))
    # Alt+[1-6] to focus tag [0-5]
    riverctl map normal Alt       $i set-focused-tags $tags
    # Alt+Shift+[1-6] to tag focused view with tag [0-5]
    riverctl map normal Alt+Shift $i set-view-tags    $tags
done

#
# Mouse bindings
#
riverctl map-pointer normal Alt         BTN_LEFT    move-view
riverctl map-pointer normal Alt         BTN_RIGHT   resize-view
riverctl map-pointer normal Alt         BTN_MIDDLE  toggle-float
riverctl map-pointer normal Alt+Shift   BTN_MIDDLE send-to-output next

#
# Colors
#
riverctl background-color       0x282828
riverctl border-color-focused   0xbdae93
riverctl border-color-unfocused 0x504945

#
# Ui
#
riverctl border-width     1
riverctl default-layout   rivercarro
riverctl xcursor-theme    "X11-Default-Black"
gsettings set org.gnome.desktop.interface       gtk-theme           "adw-gtk3-dark"
gsettings set org.gnome.desktop.interface       icon-theme          "Tela-circle-Dark"
gsettings set org.gnome.desktop.interface       cursor-theme        "Frappé-cursors"
gsettings set org.gnome.desktop.interface       document-font-name  "Ubuntu 11"
gsettings set org.gnome.desktop.interface       font-name           "Ubuntu 11"
gsettings set org.gnome.desktop.interface       monospace-font-name 'Ubuntu Mono 13'
gsettings set org.gnome.desktop.interface       font-antialiasing   "grayscale"
gsettings set org.gnome.desktop.interface       font-hinting        "slight"
gsettings set org.gnome.desktop.wm.preferences  button-layout   ""

#
# Filters
#
riverctl rule-add -title "Open File" float
riverctl rule-add -title "Save File" float
riverctl rule-add -title "Save As" float
riverctl rule-add -title "Open Folder" float
riverctl rule-add -title "Open As" float
riverctl rule-add -title "anydesk" float
riverctl rule-add -title "AnyDesk" float
riverctl rule-add -title "World of Warcraft" float
riverctl rule-add -title "Libre Office*" float
riverctl rule-add -title "Text Import*" float
riverctl rule-add -title "Battle.net" float

# Start layout generator(s)
rivercarro -outer-gaps 10 -inner-gaps 10 -no-smart-gaps &

# Start Waybar
waybar &

# Output manger
way-displays > /tmp/way-displays.${XDG_VTNR}.${USER}.log 2>&1 &

# Ilde manager
sway-audio-idle-inhibit &
swayidle -w timeout 600 'swaylock -p -C ~/.config/swaylock/chclr.conf --font "MonaspiceRn NF" --font-size 13' &

# Set wallpaper
#swaybg -i /home/vighd/Pictures/wp2.jpg &

# Fix interop
systemctl --user import-environment WAYLAND_DISPLAY XDG_CURRENT_DESKTOP PATH
dbus-update-activation-environment --systemd WAYLAND_DISPLAY XDG_CURRENT_DESKTOP=river
/usr/lib/xdg-desktop-portal-gtk &
/usr/lib/xdg-desktop-portal-wlr &

# Add support to clipboard for Xwayland
wl-paste -t text -w xclip -selection clipboard &

nekemerrenincsidom -deviceName "RAPOO Rapoo 2.4G Wireless Device Consumer Control" -mp3 /home/vighd/Documents/nekem_erre_nincs_idom.mp3,/home/vighd/Documents/mindig_egyutt.mp3,/home/vighd/Documents/dadadada.mp3,/home/vighd/Documents/baszkiah.mp3 &

# Mount daemon
udiskie -q &
